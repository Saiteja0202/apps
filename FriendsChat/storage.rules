rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat media: any signed-in user can upload/read. Files live under chat_media/{chatId}/...
    match /chat_media/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      // Limit uploads to 100 MB each; only authenticated users.
      allow write: if request.auth != null
                   && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
