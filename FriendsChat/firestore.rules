rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      // write covers create/update/delete of your own profile (delete account)
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Likes are one-directional. Anyone signed in can read them (needed to detect
    // a mutual match and to show "who liked you"), but you can only create/remove
    // your own outgoing likes.
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.fromUid;
    }

    // Passes are private bookkeeping: only the person who made the pass touches it.
    match /passes/{passId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.fromUid;
    }

    // Blocks: you can only create/remove your own blocks.
    match /blocks/{blockId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.blockerUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.blockerUid;
    }

    // Reports / vouches (genuine | fake): one per reporter per target.
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.reporterUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.reporterUid;
    }

    match /chats/{chatId} {
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      // read/update/delete allowed for members (delete used when unmatching/removing a chat)
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.members;

      match /messages/{msgId} {
        // delete used to clean up a user's messages when the account is removed
        allow read, create, update, delete: if request.auth != null;
      }
    }
  }
}
